{
    "baseURL": "https://rewards.bing.com/dashboard",
    "sessionPath": "sessions",
    "headless": true,
    "runOnZeroPoints": false,
    "clusters": 1,
    "errorDiagnostics": false,
    "workers": {
        "doDailySet": true,
        "doSpecialPromotions": true,
        "doMorePromotions": true,
        "doAppPromotions": true,
        "doDesktopSearch": true,
        "doMobileSearch": true,
        "doDailyCheckIn": true,
        "doReadToEarn": true,
        "doDailyStreak": true,
        "doDashboardInfo": true,
        "doClaimPoints": true,
        "doApplyCoupons": true
    },
    "searchOnBingLocalQueries": true,
    "globalTimeout": "30sec",
    "searchSettings": {
        "scrollRandomResults": true,
        "clickRandomResults": true,
        "parallelSearching": true,
        "queryEngines": ["google", "wikipedia", "reddit", "local"],
        "searchResultVisitTime": "10sec",
        "searchDelay": {
            "min": "30sec",
            "max": "1min"
        },
        "readDelay": {
            "min": "30sec",
            "max": "1min"
        }
    },
    "debugLogs": false,
    "consoleLogFilter": {
        "enabled": false,
        "mode": "whitelist",
        "levels": ["error", "warn"],
        "keywords": ["starting account"],
        "regexPatterns": []
    },
    "proxy": {
        "queryEngine": true
    },
    "webhook": {
        "discord": {
            "enabled": false,
            "url": ""
        },
        "ntfy": {
            "enabled": false,
            "url": "",
            "topic": "",
            "token": "",
            "title": "Microsoft-Rewards-Bot",
            "tags": ["bot", "notify"],
            "priority": 3
        },
        "webhookLogFilter": {
            "enabled": false,
            "mode": "whitelist",
            "levels": ["error"],
            "keywords": ["starting account", "select number", "collected"],
            "regexPatterns": []
        },
        "runSummary": {
            "enabled": false,
            "discordUrl": "",
            "includeCoreComparison": true
        }
    },
    "core": {
        "doubleSearchPoints": true,
        "appReward": true,
        "readToEarn": true,
        "dailyCheckIn": true,
        "dailyStreak": true,
        "redeemGoal": true,
        "claimPoints": true,
        "applyCoupons": true,
        "temporaryPunchcards": false,
        "collectDashboardInfo": true,
        "streakProtection": true,
        "dailySetUnlimited": false,
        "dashboardSync": true
    },
    "backgroundAgent": {
        "enabled": false,
        "allowDashboardAutostart": false,
        "openConsole": true
    },
    "terminal": {
        "enabled": false
    },
    "scheduler": {
        "enabled": false,
        "runOnStartup": true,
        "timezone": "Europe/Paris",
        "startTime": "08:00",
        "randomDelay": {
            "min": "0min",
            "max": "30min"
        }
    }
}
